# Copy this file to .env and fill in your actual Mailchimp credentials

# Mailchimp API Configuration
VITE_MAILCHIMP_API_KEY=your_actual_mailchimp_api_key_here
VITE_MAILCHIMP_SERVER_PREFIX=us1
VITE_MAILCHIMP_AUDIENCE_ID=your_actual_audience_id_here

# How to get these values:
# 1. API Key: Go to Mailchimp > Account > Extras > API keys
# 2. Server Prefix: It's the part after the dash in your API key (e.g., if your key ends with "-us1", use "us1")
# 3. Audience ID: Go to Mailchimp > Audience > Settings > Audience name and defaults
